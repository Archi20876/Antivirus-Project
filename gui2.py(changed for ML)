def hips_insert_line(line):
    if "[HIGH]" in line:
        tag = "high"
    elif "[MEDIUM]" in line or "[RESPONSE]" in line:
        tag = "medium"
    elif "[LOW]" in line:
        tag = "low"
    else:
        tag = "info"
    output_text_hips.insert(END, line, tag)
    output_text_hips.see(END)
    
# [HIPS INTEGRATION] Background thread: reads hips stdout line-by-line.
def hips_read_output():
    global process_hips
    in_suspended_block = False
    suspended_lines = []
    while True:
        output_line = process_hips.stdout.readline()
        if output_line == '' and process_hips.poll() is not None:
            break
        if not output_line:
            continue
        if "[HIPS][SUSPENDED_LIST]" in output_line and "END" not in output_line:
            in_suspended_block = True
            suspended_lines = []
            continue
        if "[HIPS][SUSPENDED_LIST_END]" in output_line:
            in_suspended_block = False
            root.after(0, lambda lines=suspended_lines: hips_refresh_suspended_listbox(lines))
            continue
        if in_suspended_block:
            suspended_lines.append(output_line.strip())
            continue
        root.after(0, lambda l=output_line: hips_insert_line(l))
    process_hips.stdout.close()
    
# [HIPS INTEGRATION] Populate the suspended-process listbox from parsed lines.
def hips_refresh_suspended_listbox(lines):
    hips_suspended_listbox.delete(0, END)
    for line in lines:
        if line:
            hips_suspended_listbox.insert(END, line)
            
# [HIPS INTEGRATION] Send a text command to hips stdin.
def hips_send_command(cmd):
    global process_hips
    if process_hips and process_hips.poll() is None:
        try:
            process_hips.stdin.write(cmd + "\n")
            process_hips.stdin.flush()
        except Exception:
            pass
            
# [HIPS INTEGRATION] Toggle HIPS on/off.
def toggle_hips():
    global process_hips
    if hips_switch_var.get() == 1:
        hips_switch_button.config(text="Enabled", fg="#12c4c0")
        if os.geteuid() != 0:
            hips_insert_line("[!] Warning: not running as root. SIGSTOP/SIGKILL may fail on other users' processes.\n")
        process_hips = subprocess.Popen(
            [ENGINE_HIPS_PATH],
            stdout=subprocess.PIPE,
            stdin=subprocess.PIPE,
            universal_newlines=True
        )
        reader = threading.Thread(target=hips_read_output, daemon=True)
        reader.start()
    else:
        hips_switch_button.config(text="Disabled", fg="Black")
        if process_hips is not None:
            hips_send_command("q")
            process_hips.kill()
            
# [HIPS INTEGRATION] Ask hips to send its suspended list.
def hips_refresh_list():
    hips_send_command("list")
    
# [HIPS INTEGRATION] Resume the process selected in the suspended listbox.
def hips_resume_selected():
    selection = hips_suspended_listbox.curselection()
    if not selection:
        return
    entry = hips_suspended_listbox.get(selection[0])
    for part in entry.split():
        if part.startswith("pid="):
            pid = part.split("=")[1]
            hips_send_command(f"resume {pid}")
            hips_refresh_list()
            break
            
